# ====================================================================
# 瑞鑫咖啡店管理系统 - 环境变量示例文件
# ====================================================================
# 使用说明：
# 1. 复制本文件为 .env （cp .env.example .env）
# 2. 将下方占位符替换为你自己的真实凭证
# 3. .env 文件已被 .gitignore 忽略，不会提交到仓库
# 4. 仅 VITE_ 前缀变量会暴露给前端代码（通过 import.meta.env 访问）
# 5. 切勿在 .env 中存放任何需要在服务端保密的密钥（前端环境变量最终会被打包进静态产物，可被用户查看）
# ====================================================================

# 后端接口基础地址
VITE_APP_API_BASE_URL=https://kf.webxyq.com

# 后端接口访问凭证 appkey（请替换为你自己注册获取的 appkey）
VITE_APP_APPKEY=your_appkey_here
